# Copy this file to .env and fill in what you have.

PORT=3000
CORS_ORIGIN=*

# Where the SQLite file lives. Default is fine for local dev; on a
# host with an ephemeral filesystem (some free tiers wipe disk on
# redeploy), point this at a persistent volume/disk instead.
DB_PATH=./blink.db

# Required for POST/PUT/DELETE /api/courses and POST /api/sync.
# Pick any long random string.
ADMIN_API_KEY=change-me-to-something-random

# Used to sign user login tokens (separate secret from ADMIN_API_KEY).
# Pick another long random string. Changing this logs everyone out.
JWT_SECRET=change-me-to-something-else-random

# Set to a number > 0 to auto-sync in the background every N minutes.
# Leave at 0 and just run `npm run sync` manually (or wire it to a
# cron job / your host's scheduler) if you'd rather control timing.
SYNC_INTERVAL_MINUTES=0

# --- Coursera --------------------------------------------------------
# The Catalog API is public and needs NO key. Nothing to fill in here.

# --- edX ---------------------------------------------------------------
# Apply for API access at https://api.edx.org — you'll get a client ID,
# client secret, and the exact token/base URLs in the approval email
# (these vary slightly by partner, so double-check against what edX
# sends you).
EDX_CLIENT_ID=
EDX_CLIENT_SECRET=
EDX_TOKEN_URL=https://api.edx.org/oauth2/v1/access_token
EDX_CATALOG_BASE_URL=https://api.edx.org/catalog/v1

# --- Udemy ---------------------------------------------------------------
# You must first be accepted into the Udemy Affiliate Program (via
# Impact) at https://www.udemy.com/affiliate/ before Udemy will issue
# API credentials. Once approved, create an API client at
# https://www.udemy.com/instructor/api-clients/ and paste them below.
UDEMY_CLIENT_ID=
UDEMY_CLIENT_SECRET=
